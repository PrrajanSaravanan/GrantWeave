# ============================================================
# GrantWeave — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# TinyFish Web Agent API key (Pro tier supports 50 concurrent agents)
# Get yours at https://tinyfish.ai
TINYFISH_API_KEY=your_tinyfish_api_key_here

# TinyFish API endpoint (do not change)
TINYFISH_ENDPOINT=https://agent.tinyfish.ai/v1/automation/run-sse

# SQLite database path (relative to backend/)
DB_PATH=aetherforge.db

# Backend server port
PORT=8000

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Max concurrent TinyFish agents (Pro tier = 50)
MAX_AGENTS=50

# Session secret for team handoff links
SESSION_SECRET=changeme_use_a_random_string_here
